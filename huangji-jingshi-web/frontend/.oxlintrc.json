{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**"
  ],
  "plugins": [
    "eslint",
    "typescript",
    "oxc"
  ],
  "rules": {
    "eslint/no-shadow": "off"
  }
}
